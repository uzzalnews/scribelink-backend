# Choose one provider: "openai", "assemblyai", or "gemini"
TRANSCRIBE_PROVIDER=gemini

# Required if TRANSCRIBE_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Required if TRANSCRIBE_PROVIDER=assemblyai
ASSEMBLYAI_API_KEY=...

# Required if TRANSCRIBE_PROVIDER=gemini
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=...
# Optional: override the default model (gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

PORT=3000
